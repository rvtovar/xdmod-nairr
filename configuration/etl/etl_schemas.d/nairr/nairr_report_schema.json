{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NAIRR Report Access",
  "type": "object",
  "properties": {
    "nairr_report_id": {
      "type": "string",
      "description": "NAIRR Report Identifier",
      "maxLength": 64
    },
    "user_email": {
      "type": "string",
      "description": "Email of the user accessing the report",
      "maxLength": 255
    }
  },
  "required": ["nairr_report_id", "user_email"]
}
